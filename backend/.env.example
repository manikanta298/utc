# ── Server
PORT=5000
NODE_ENV=development

# ── MongoDB
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?appName=APP

# ── JWT (REQUIRED — use strong random strings, min 32 chars each)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Setup key (for /api/auth/setup-master — disable after first use)
SETUP_KEY=replace-with-strong-random-key

# ── Seed secret (for /api/auth/seed-demo)
SEED_SECRET=replace-with-seed-secret

# ── Master admin credentials (used by setup-master)
MASTER_EMAIL=admin@utccafe.com
MASTER_PASSWORD=ChangeMe@1234

# ── Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app-password

# ── Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Twilio SMS
TWILIO_SID=your-twilio-sid
TWILIO_TOKEN=your-twilio-token
TWILIO_PHONE=your-twilio-phone
SMS_ENABLED=false

# ── Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173
