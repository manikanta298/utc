# ── Server
PORT=5000
NODE_ENV=development

# ── MongoDB
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?appName=APP

# ── JWT (REQUIRED — use strong random strings, min 32 chars each)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Setup key (for /api/auth/setup-master — disable after first use)
SETUP_KEY=replace-with-strong-random-key

# ── Seed secret (for /api/auth/seed-demo)
SEED_SECRET=replace-with-seed-secret

# ── Master admin credentials (used by setup-master)
MASTER_EMAIL=admin@utccafe.com
MASTER_PASSWORD=ChangeMe@1234

# ── Brevo (transactional email — this is what utils/mailer.js actually reads)
BREVO_API_KEY=replace-with-your-brevo-api-key
BREVO_SENDER=you@example.com

# ── Security alerts (account lockouts, high memory, Mongo disconnects)
# Sent via the Brevo mailer above. Falls back to MASTER_EMAIL if unset.
SECURITY_ALERT_EMAIL=you@example.com

# ── CockroachDB (order tracking history + customer sync — downstream of MongoDB)
COCKROACH_DATABASE_URL=postgresql://USER:PASSWORD@HOST:26257/DBNAME?sslmode=verify-full

# ── Cloudinary (menu images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Twilio SMS
TWILIO_SID=your-twilio-sid
TWILIO_TOKEN=your-twilio-token
TWILIO_PHONE=your-twilio-phone
SMS_ENABLED=false

# ── Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173
